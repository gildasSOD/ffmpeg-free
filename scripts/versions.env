# Pinned upstream versions for reproducible builds.
# Bump deliberately; every change is a new release. Verify each tag exists before relying on it
# (these were chosen as known-good as of 2026-05; CI fails loudly on a bad tag rather than drifting).
#
# All codec libraries below are BSD/MIT/LGPL — none triggers FFmpeg's --enable-gpl or
# --enable-nonfree. See README.md "Dependency licenses".

# --- FFmpeg itself (latest stable series; libpostproc removed in 8.0) ---
FFMPEG_VERSION=8.1.1

# --- AV1 (royalty-free: AOMedia Patent License 1.0) ---
DAV1D_VERSION=1.4.3          # AV1 decoder (VideoLAN, BSD-2-Clause), meson build
SVTAV1_VERSION=2.3.0         # AV1 encoder, fast (BSD-3-Clause-Clear), cmake
AOM_VERSION=3.10.0           # AV1 reference enc/dec (BSD-2-Clause), cmake

# --- VP8/VP9 (royalty-free: Google grant) ---
LIBVPX_VERSION=1.14.1        # BSD-3-Clause, autotools

# --- Audio (royalty-free) ---
OPUS_VERSION=1.5.2           # Opus (BSD-3-Clause), autotools
OGG_VERSION=1.3.5            # Ogg container (BSD), needed by Vorbis
VORBIS_VERSION=1.3.7         # Vorbis (BSD-3-Clause), autotools
LAME_VERSION=3.100           # MP3 encoder (LGPL; MP3 patents expired), autotools

# --- Image ---
LIBWEBP_VERSION=1.4.0        # WebP (BSD-3-Clause), cmake/autotools

# --- NVIDIA NVENC/NVDEC API headers (MIT). Must match the target driver's SDK version.
#     This is the FREE path — we never build libnpp / cuda-nvcc (those are FFmpeg "nonfree"). ---
NVCODEC_HEADERS_VERSION=12.2.72.0

# --- Jetson / L4T base image (JetPack 6.2 == L4T r36.4.x). r36.4.3 has been intermittently
#     missing from NGC; r36.4.0 is the stable fallback. Override via the build.yml input. ---
L4T_JETPACK_TAG=r36.4.0
